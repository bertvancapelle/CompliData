# LIKARA — voorbeeld-omgevingsvariabelen.
# Kopieer naar .env en vul in. .env NOOIT committen.

# Database
POSTGRES_PASSWORD=changeme_dev
DATABASE_URL=postgresql+asyncpg://cd_app:changeme_dev@localhost:5432/complidata
DATABASE_URL_SYNC=postgresql://cd_app:changeme_dev@localhost:5432/complidata
ADMIN_DATABASE_URL=postgresql+asyncpg://cd_admin:changeme_dev@localhost:5432/complidata

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_EXTERNAL_URL=http://localhost:8080
KEYCLOAK_REALM=complidata
KEYCLOAK_CLIENT_ID=complidata-api
KEYCLOAK_CLIENT_SECRET=changeme_dev
KEYCLOAK_ADMIN_PASSWORD=changeme_dev

# RabbitMQ
RABBITMQ_PASSWORD=changeme_dev
RABBITMQ_URL=amqp://cd_rabbit:changeme_dev@localhost:5672/

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ROOT_USER=complidata_admin
MINIO_ROOT_PASSWORD=changeme_dev_only
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_EXTERNAL_URL=http://localhost:9000

# Cookies (dev: secure=false zodat http werkt)
COOKIE_SECURE=false
